{"number":86,"name":"سُورَةُ الطَّارِقِ","englishName":"At-Taariq","englishNameTranslation":"The Morning Star","revelationType":"Meccan","ayahs":[{"n":1,"g":5932,"ar":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ","bn":"শপথ আকাশের এবং রাত্রিতে আগমনকারীর।"},{"n":2,"g":5933,"ar":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ","bn":"আপনি জানেন, যে রাত্রিতে আসে সেটা কি?"},{"n":3,"g":5934,"ar":"ٱلنَّجْمُ ٱلثَّاقِبُ","bn":"সেটা এক উজ্জ্বল নক্ষত্র।"},{"n":4,"g":5935,"ar":"إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ","bn":"প্রত্যেকের উপর একজন তত্ত্বাবধায়ক রয়েছে।"},{"n":5,"g":5936,"ar":"فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ","bn":"অতএব, মানুষের দেখা উচিত কি বস্তু থেকে সে সৃজিত হয়েছে।"},{"n":6,"g":5937,"ar":"خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ","bn":"সে সৃজিত হয়েছে সবেগে স্খলিত পানি থেকে।"},{"n":7,"g":5938,"ar":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ","bn":"এটা নির্গত হয় মেরুদন্ড ও বক্ষপাজরের মধ্য থেকে।"},{"n":8,"g":5939,"ar":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ","bn":"নিশ্চয় তিনি তাকে ফিরিয়ে নিতে সক্ষম।"},{"n":9,"g":5940,"ar":"يَوْمَ تُبْلَى ٱلسَّرَآئِرُ","bn":"যেদিন গোপন বিষয়াদি পরীক্ষিত হবে,"},{"n":10,"g":5941,"ar":"فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ","bn":"সেদিন তার কোন শক্তি থাকবে না এবং সাহায্যকারীও থাকবে না।"},{"n":11,"g":5942,"ar":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ","bn":"শপথ চক্রশীল আকাশের"},{"n":12,"g":5943,"ar":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ","bn":"এবং বিদারনশীল পৃথিবীর"},{"n":13,"g":5944,"ar":"إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ","bn":"নিশ্চয় কোরআন সত্য-মিথ্যার ফয়সালা।"},{"n":14,"g":5945,"ar":"وَمَا هُوَ بِٱلْهَزْلِ","bn":"এবং এটা উপহাস নয়।"},{"n":15,"g":5946,"ar":"إِنَّهُمْ يَكِيدُونَ كَيْدًۭا","bn":"তারা ভীষণ চক্রান্ত করে,"},{"n":16,"g":5947,"ar":"وَأَكِيدُ كَيْدًۭا","bn":"আর আমিও কৌশল করি।"},{"n":17,"g":5948,"ar":"فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا","bn":"অতএব, কাফেরদেরকে অবকাশ দিন, তাদেরকে অবকাশ দিন, কিছু দিনের জন্যে।"}]}