{"number":88,"name":"سُورَةُ الغَاشِيَةِ","englishName":"Al-Ghaashiya","englishNameTranslation":"The Overwhelming","revelationType":"Meccan","ayahs":[{"n":1,"g":5968,"ar":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ","bn":"আপনার কাছে আচ্ছন্নকারী কেয়ামতের বৃত্তান্ত পৌঁছেছে কি?"},{"n":2,"g":5969,"ar":"وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ","bn":"অনেক মুখমন্ডল সেদিন হবে লাঞ্ছিত,"},{"n":3,"g":5970,"ar":"عَامِلَةٌۭ نَّاصِبَةٌۭ","bn":"ক্লিষ্ট, ক্লান্ত।"},{"n":4,"g":5971,"ar":"تَصْلَىٰ نَارًا حَامِيَةًۭ","bn":"তারা জ্বলন্ত আগুনে পতিত হবে।"},{"n":5,"g":5972,"ar":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ","bn":"তাদেরকে ফুটন্ত নহর থেকে পান করানো হবে।"},{"n":6,"g":5973,"ar":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ","bn":"কন্টকপূর্ণ ঝাড় ব্যতীত তাদের জন্যে কোন খাদ্য নেই।"},{"n":7,"g":5974,"ar":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ","bn":"এটা তাদেরকে পুষ্ট করবে না এবং ক্ষুধায়ও উপকার করবে না।"},{"n":8,"g":5975,"ar":"وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ","bn":"অনেক মুখমন্ডল সেদিন হবে, সজীব,"},{"n":9,"g":5976,"ar":"لِّسَعْيِهَا رَاضِيَةٌۭ","bn":"তাদের কর্মের কারণে সন্তুষ্ট।"},{"n":10,"g":5977,"ar":"فِى جَنَّةٍ عَالِيَةٍۢ","bn":"তারা থাকবে, সুউচ্চ জান্নাতে।"},{"n":11,"g":5978,"ar":"لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ","bn":"তথায় শুনবে না কোন অসার কথাবার্তা।"},{"n":12,"g":5979,"ar":"فِيهَا عَيْنٌۭ جَارِيَةٌۭ","bn":"তথায় থাকবে প্রবাহিত ঝরণা।"},{"n":13,"g":5980,"ar":"فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ","bn":"তথায় থাকবে উন্নত সুসজ্জিত আসন।"},{"n":14,"g":5981,"ar":"وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ","bn":"এবং সংরক্ষিত পানপাত্র"},{"n":15,"g":5982,"ar":"وَنَمَارِقُ مَصْفُوفَةٌۭ","bn":"এবং সারি সারি গালিচা"},{"n":16,"g":5983,"ar":"وَزَرَابِىُّ مَبْثُوثَةٌ","bn":"এবং বিস্তৃত বিছানো কার্পেট।"},{"n":17,"g":5984,"ar":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","bn":"তারা কি উষ্ট্রের প্রতি লক্ষ্য করে না যে, তা কিভাবে সৃষ্টি করা হয়েছে?"},{"n":18,"g":5985,"ar":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","bn":"এবং আকাশের প্রতি লক্ষ্য করে না যে, তা কিভাবে উচ্চ করা হয়েছে?"},{"n":19,"g":5986,"ar":"