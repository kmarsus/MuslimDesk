{"number":101,"name":"سُورَةُ القَارِعَةِ","englishName":"Al-Qaari'a","englishNameTranslation":"The Calamity","revelationType":"Meccan","ayahs":[{"n":1,"g":6158,"ar":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ","bn":"করাঘাতকারী,"},{"n":2,"g":6159,"ar":"مَا ٱلْقَارِعَةُ","bn":"করাঘাতকারী কি?"},{"n":3,"g":6160,"ar":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ","bn":"করাঘাতকারী সম্পর্কে আপনি কি জানেন ?"},{"n":4,"g":6161,"ar":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ","bn":"যেদিন মানুষ হবে বিক্ষিপ্ত পতংগের মত"},{"n":5,"g":6162,"ar":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ","bn":"এবং পর্বতমালা হবে ধুনিত রঙ্গীন পশমের মত।"},{"n":6,"g":6163,"ar":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ","bn":"অতএব যার পাল্লা ভারী হবে,"},{"n":7,"g":6164,"ar":"فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ","bn":"সে সুখীজীবন যাপন করবে।"},{"n":8,"g":6165,"ar":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ","bn":"আর যার পাল্লা হালকা হবে,"},{"n":9,"g":6166,"ar":"فَأُمُّهُۥ هَاوِيَةٌۭ","bn":"তার ঠিকানা হবে হাবিয়া।"},{"n":10,"g":6167,"ar":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ","bn":"আপনি জানেন তা কি?"},{"n":11,"g":6168,"ar":"نَارٌ حَامِيَةٌۢ","bn":"প্রজ্জ্বলিত অগ্নি!"}]}