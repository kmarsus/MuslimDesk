{"number":104,"name":"سُورَةُ الهُمَزَةِ","englishName":"Al-Humaza","englishNameTranslation":"The Traducer","revelationType":"Meccan","ayahs":[{"n":1,"g":6180,"ar":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ","bn":"প্রত্যেক পশ্চাতে ও সম্মুখে পরনিন্দাকারীর দুর্ভোগ,"},{"n":2,"g":6181,"ar":"ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ","bn":"যে অর্থ সঞ্চিত করে ও গণনা করে"},{"n":3,"g":6182,"ar":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","bn":"সে মনে করে যে, তার অর্থ চিরকাল তার সাথে থাকবে!"},{"n":4,"g":6183,"ar":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","bn":"কখনও না, সে অবশ্যই নিক্ষিপ্ত হবে পিষ্টকারীর মধ্যে।"},{"n":5,"g":6184,"ar":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","bn":"আপনি কি জানেন, পিষ্টকারী কি?"},{"n":6,"g":6185,"ar":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","bn":"এটা আল্লাহর প্রজ্জ্বলিত অগ্নি,"},{"n":7,"g":6186,"ar":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","bn":"যা হৃদয় পর্যন্ত পৌছবে।"},{"n":8,"g":6187,"ar":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ","bn":"এতে তাদেরকে বেঁধে দেয়া হবে,"},{"n":9,"g":6188,"ar":"فِى عَمَدٍۢ مُّمَدَّدَةٍۭ","bn":"লম্বা লম্বা খুঁটিতে।"}]}